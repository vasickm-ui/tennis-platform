generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model account {
  id_account BigInt @id @default(autoincrement())
  emial      String @db.VarChar(50)
  person_id  BigInt
  person     person @relation(fields: [person_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_person_account")
}

model person {
  id         BigInt    @id @default(autoincrement())
  first_name String    @db.VarChar(50)
  last_name  String    @db.VarChar(50)
  account    account[]
}
